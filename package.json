{
  "name": "kubed",
  "version": "1.0.0",
  "description": "Kubernetes automatic deployer",
  "main": "index.js",
  "bin": "dist/index.js",
  "exports": "./dist/index.js",
  "typings": "dist/index.d.ts",
  "engines": {
    "node": ">=18.20.5"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "clean": "rimraf dist/",
    "build": "npm run clean && tsc",
    "build:ncc": "npm run clean && ncc build ./src/index.ts --target es2020 -a -m -o dist",
    "start:prod": "node dist/index.js",
    "start": "npm run --silent build && node dist/index.js",
    "lint": "eslint .",
    "lint:ci": "eslint . --cache --cache-location ./node_modules/.cache/eslint/.eslintcache",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:ci": "prettier --check --cache .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "package": "ts-node ./tools/scripts/package.ts",
    "package:linux:amd64": "npm run package -- --os linux:amd64",
    "package:linux:arm64": "npm run package -- --os linux:arm64",
    "package:darwin:amd64": "npm run package -- --os darwin:amd64",
    "package:darwin:arm64": "npm run package -- --os darwin:arm64",
    "package:windows:amd64": "npm run package -- --os windows:amd64",
    "package:linux:amd64:offline": "npm run package -- --os linux:amd64 --with-deps",
    "package:linux:arm64:offline": "npm run package -- --os linux:arm64 --with-deps",
    "package:darwin:amd64:offline": "npm run package -- --os darwin:amd64 --with-deps",
    "package:darwin:arm64:offline": "npm run package -- --os darwin:arm64 --with-deps",
    "package:windows:amd64:offline": "npm run package -- --os windows:amd64 --with-deps"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no-install commitlint --edit $1",
    "pre-commit": "npm run format:check && npm run lint && npm run test",
    "preserveUnused": false
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "asciiart-logo": "^0.2.7",
    "axios": "^1.8.4",
    "cli-table3": "^0.6.5",
    "colorette": "^2.0.20",
    "commander": "^13.1.0",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.3.0",
    "html-entities": "^2.6.0",
    "js-yaml": "^4.1.0",
    "listr2": "^7.0.2",
    "lodash": "^4.17.21",
    "nunjucks": "^3.2.4",
    "randomstring": "^1.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/decompress": "^4.2.7",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/listr": "^0.14.9",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20.17.30",
    "@types/nunjucks": "^3.2.6",
    "@types/randomstring": "^1.3.0",
    "@vercel/ncc": "^0.38.3",
    "@yao-pkg/pkg": "^6.3.2",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.5.0",
    "lint-staged": "^15.5.0",
    "onchange": "^7.1.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "run-script-os": "^1.1.6",
    "simple-git-hooks": "^2.12.1",
    "swc-loader": "^0.2.6",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@stylistic/eslint-plugin-ts": "^4.2.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --cache-location ./node_modules/.cache/eslint/.eslintcache",
    "*": "prettier --list-different --ignore-unknown"
  },
  "pkg": {
    "scripts": [
      "./dist/**/*.js"
    ],
    "assets": [
      "dist",
      "assets",
      ".application"
    ]
  }
}
